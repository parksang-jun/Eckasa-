# ============================================================
#  ECKASA 릴스 광고 자동화 - 환경설정 예시
#  이 파일을 복사해 ".env" 로 만들고 값을 채워 넣으세요.
#  (.env 는 절대 깃/공개 저장소에 올리지 마세요)
# ============================================================

# ---------- 사이트 / 크롤링 ----------
ECKASA_BASE_URL=https://eckasa.com
# 광고로 만들 제품이 들어있는 카테고리 번호들 (쉼표로 구분). 예: 45,50
ECKASA_CATEGORY_NOS=45

# ---------- ffmpeg ----------
# Windows 예: C:\ffmpeg\bin\ffmpeg.exe  /  PATH 에 있으면 그냥 ffmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ---------- Anthropic (광고 카피 생성) ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 카피 생성 모델 (저비용: claude-haiku-4-5 / 고품질: claude-opus-4-8)
COPY_MODEL=claude-haiku-4-5
# 광고 톤: emotional(감성) | practical(실용) | trendy(트렌디)
COPY_TONE=trendy

# ---------- fal.ai (이미지→영상 AI 클립) ----------
# 미설정 시 AI 클립 없이 이미지 슬라이드쇼(Ken-Burns)만 사용
FAL_KEY=
# fal.ai 모델 엔드포인트 (Kling 권장: 저비용)
FAL_VIDEO_MODEL=fal-ai/kling-video/v1/standard/image-to-video
# 제품당 생성할 AI 클립 길이(초) / 개수 — 비용 제한
AI_CLIP_SECONDS=5
AI_CLIP_COUNT=1
# 안전모드: true 면 AI 클립을 인트로에만 쓰고 본문은 실제 제품 이미지 위주
SAFE_MODE=true

# ---------- 장면 광고 (모델 + 이국적 배경 합성) ----------
# [무료 경로] Google AI Studio(Gemini) 키 — 결제 불필요, 하루 ~500장 무료
#   발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# 이미지 백엔드: auto(무료 Gemini 우선) | gemini | fal
IMAGE_PROVIDER=auto
# [유료 대안] fal.ai nano-banana (이미지당 약 $0.039)
FAL_IMAGE_MODEL=fal-ai/nano-banana/edit
# 기본 배경/모델 프리셋 (대시보드 스튜디오에서 변경 가능)
# 배경: europe_street | santorini | bali_beach | morocco
DEFAULT_BACKGROUND=europe_street
# 모델: western_female | asian_female | male_unisex | no_model
DEFAULT_MODEL=western_female
# 한 광고에 만들 장면(컷) 수 = 이미지/영상 클립 수 (많을수록 비용↑)
SCENE_COUNT=2
# 마지막에 실제 제품 스튜디오 컷 + 가격/CTA 붙이기
INCLUDE_CLOSING_SHOT=true

# ---------- 영상 스펙 ----------
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# 제품 이미지 한 장당 노출 시간(초)
SLIDE_SECONDS=2.5

# ---------- 공개 스토리지 (Cloudflare R2 / AWS S3, S3 호환) ----------
# Instagram 이 영상을 가져갈 수 있도록 공개 URL 이 필요합니다.
STORAGE_PROVIDER=r2            # r2 | s3 | local
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=eckasa-reels
S3_REGION=auto
# 버킷에 연결된 공개 도메인 (R2 Public Bucket / 커스텀 도메인)
S3_PUBLIC_BASE_URL=https://media.example.com

# STORAGE_PROVIDER=local 일 때 (개발용): cloudflared/ngrok 터널의 공개 베이스 URL
LOCAL_PUBLIC_BASE_URL=

# ---------- Instagram Graph API ----------
# 비즈니스 계정 + 연결된 페이스북 페이지 + 콘텐츠 게시 권한 필요
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_GRAPH_VERSION=v21.0

# ---------- 스케줄러 ----------
# cron 식 (APScheduler). 예: 매일 오전 10시 -> 0 10 * * *
SCHEDULE_CRON=0 10 * * *
# true 면 서버 시작 시 스케줄러 자동 활성화
SCHEDULE_ENABLED=false

# ---------- 브랜드 ----------
BRAND_NAME=ECKASA
DEFAULT_HASHTAGS=#엑카사 #ECKASA #가방 #데일리백 #감성가방
