# 이 파일을 복사해 .env 로 저장한 뒤 값을 채워 넣으세요.

# --- Anthropic (Claude) ---
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=
# 분석/명세서 작성 모델. 품질 우선이면 claude-opus-4-8, 균형은 claude-sonnet-4-6
ANALYSIS_MODEL=claude-sonnet-4-6

# --- KIPRIS (한국특허정보원) 선행특허 검색 ---
# https://plus.kipris.or.kr 회원가입 → 마이페이지에서 서비스키(인증키) 발급 (무료)
# 키가 없으면 선행특허 검색만 비활성화되고 나머지 기능은 정상 동작합니다.
KIPRIS_API_KEY=

# 검색 시 키워드당 가져올 최대 선행특허 건수
KIPRIS_ROWS_PER_KEYWORD=5
